# 401(k) CRM SaaS - Environment Configuration Template
# Rename this file to .env and configure local values

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/db_name

# FastAPI Configuration
SECRET_KEY=generate-a-secure-secret-key-here
ENVIRONMENT=development
PORT=8000

# Authentication & Identity (Clerk / Auth0)
CLERK_API_URL=https://api.clerk.com/v1
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_JWT_VERIFICATION_KEY=your_clerk_jwt_key

# Payment & Subscription Billing (Stripe)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Corporate Contact Enrichment API (Apollo / Hunter)
APOLLO_API_KEY=your_apollo_api_key
HUNTER_API_KEY=your_hunter_api_key

# File & Data Storage Paths
EXCEL_PROSPECT_FILE=Combined 401k Prospecting Plan.xlsx
DOL_DATA_DIR=.
EXTRACTED_DATA_DIR=extracted_data
